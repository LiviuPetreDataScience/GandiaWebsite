---
interface Props {
	title: string;
	lang: 'en' | 'es';
	description: string;
	otherLangHref: string;
	otherLangLabel: string;
}

const { title, lang, description, otherLangHref, otherLangLabel } = Astro.props;

const nav = lang === 'es'
	? {
		brand: 'Gandía 2026',
		home: { href: '/es/', label: 'Inicio' },
		items: [
			{ href: '/es/mar/', label: 'Mar' },
			{ href: '/es/montana/', label: 'Montaña' },
			{ href: '/es/actividades/', label: 'Actividades' },
			{ href: '/es/gastronomia/', label: 'Gastronomía' },
			{ href: '/es/hoteles/', label: 'Hoteles' },
		],
	}
	: {
		brand: 'Gandía 2026',
		home: { href: '/', label: 'Home' },
		items: [
			{ href: '/sea/', label: 'Sea' },
			{ href: '/mountain/', label: 'Mountain' },
			{ href: '/activities/', label: 'Activities' },
			{ href: '/food/', label: 'Food' },
			{ href: '/hotels/', label: 'Hotels' },
		],
	};

const path = Astro.url.pathname.replace(/\/+$/, '') + '/';
const isActive = (href: string) => path === href;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href={nav.home.href}>{nav.brand}</a>
			<nav class="primary" aria-label="Primary">
				{nav.items.map((item) => (
					<a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
						{item.label}
					</a>
				))}
			</nav>
			<nav class="lang" aria-label="Language">
				<a href={otherLangHref} hreflang={otherLangHref.startsWith('/es') ? 'es' : 'en'}>
					{otherLangLabel}
				</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<style is:global>
			:root {
				--ink: #1f1b16;
				--muted: #6b6258;
				--soft: #8d8478;
				--accent: #c0682a;
				--accent-soft: #e8b894;
				--bg: #faf5ec;
				--paper: #ffffff;
				--rule: #e6dcc8;
			}
			* { box-sizing: border-box; }
			html, body { margin: 0; padding: 0; }
			body {
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
				color: var(--ink);
				background: var(--bg);
				line-height: 1.7;
				font-size: 17px;
				-webkit-font-smoothing: antialiased;
			}
			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1.2rem;
				padding: 1.1rem 1.8rem;
				border-bottom: 1px solid var(--rule);
				background: rgba(250, 245, 236, 0.92);
				backdrop-filter: saturate(140%) blur(6px);
				position: sticky;
				top: 0;
				z-index: 10;
				flex-wrap: wrap;
			}
			.brand {
				font-family: Georgia, "Times New Roman", serif;
				font-size: 1.15rem;
				font-weight: 700;
				letter-spacing: -0.01em;
				color: var(--ink);
				text-decoration: none;
			}
			.brand:hover { color: var(--accent); }
			.primary {
				display: flex;
				gap: 1.6rem;
				margin: 0 auto 0 1.2rem;
			}
			.nav-link {
				color: var(--muted);
				text-decoration: none;
				font-size: 0.95rem;
				padding: 0.2rem 0;
				border-bottom: 1.5px solid transparent;
				transition: color 0.15s, border-color 0.15s;
			}
			.nav-link:hover { color: var(--accent); }
			.nav-link.active {
				color: var(--ink);
				border-bottom-color: var(--accent);
			}
			.lang a {
				color: var(--soft);
				text-decoration: none;
				font-size: 0.85rem;
				letter-spacing: 0.05em;
				border-bottom: 1px solid var(--rule);
				padding-bottom: 2px;
			}
			.lang a:hover {
				color: var(--accent);
				border-color: var(--accent);
			}
			main {
				max-width: 820px;
				margin: 0 auto;
				padding: 5.5rem 1.5rem 6rem;
			}
			.eyebrow {
				display: flex;
				align-items: center;
				gap: 0.95rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				font-size: 0.92rem;
				color: var(--accent);
				font-weight: 700;
				margin: 0 0 1.5rem;
			}
			.eyebrow::before {
				content: "";
				flex: 0 0 auto;
				width: 2.6rem;
				height: 2px;
				background: var(--accent);
			}
			h1 {
				font-family: Georgia, "Times New Roman", serif;
				font-weight: 700;
				font-size: clamp(2.4rem, 6vw, 3.8rem);
				line-height: 1.1;
				margin: 0 0 2.6rem;
				letter-spacing: -0.02em;
				color: var(--ink);
				text-align: center;
			}
			h1 .accent {
				color: var(--accent);
				font-style: italic;
				font-weight: 400;
			}
			.tagline {
				font-family: Georgia, "Times New Roman", serif;
				font-size: 1.3rem;
				color: var(--soft);
				font-style: italic;
				margin: 0.8rem 0 2.4rem;
				line-height: 1.45;
			}
			p { margin: 0 0 1.4rem; }
			.cta-top { margin: 0 0 1.6rem; text-align: center; }
			.cta {
				display: inline-block;
				background: #1f1b16;
				color: #ffffff;
				text-decoration: none;
				font-weight: 600;
				font-size: 0.92rem;
				padding: 0.7rem 1.4rem;
				border-radius: 999px;
				letter-spacing: 0.005em;
				white-space: nowrap;
				box-shadow: 0 6px 18px rgba(31, 27, 22, 0.22);
				transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
			}
			.cta:hover {
				background: #000000;
				transform: translateY(-1px);
				box-shadow: 0 9px 22px rgba(31, 27, 22, 0.32);
			}
			.lead {
				font-size: 1.12rem;
				color: var(--ink);
				margin-top: 0.4rem;
				margin-bottom: 2rem;
			}
			.lead::first-letter {
				font-family: Georgia, "Times New Roman", serif;
				font-size: 3.6rem;
				line-height: 0.9;
				float: left;
				padding: 0.35rem 0.7rem 0 0;
				color: var(--accent);
				font-weight: 700;
			}
			.eclipse-card {
				background: linear-gradient(135deg, #f9ecd6 0%, #f3dcb8 100%);
				border-left: 4px solid var(--accent);
				border-radius: 10px;
				padding: 1.6rem 1.9rem 0.6rem;
				margin: 2.6rem 0;
				box-shadow: 0 2px 14px rgba(192, 104, 42, 0.08);
			}
			.eclipse-eyebrow {
				font-family: Georgia, "Times New Roman", serif;
				text-transform: uppercase;
				letter-spacing: 0.18em;
				font-size: 0.78rem;
				color: var(--accent);
				font-weight: 700;
				margin: 0 0 0.7rem;
			}
			.eclipse-card p:last-child { margin-bottom: 1rem; }
			.eclipse-map { margin: 0.4rem 0 1.4rem; }
			.eclipse-map img {
				aspect-ratio: auto;
				object-fit: contain;
				background: var(--paper);
				border-radius: 6px;
				box-shadow: 0 2px 12px rgba(31, 27, 22, 0.08);
			}
			.eclipse-map figcaption {
				font-size: 0.78rem;
				margin-top: 0.6rem;
				text-align: center;
			}
			.tailor {
				margin-top: 2.4rem;
			}
			.pull {
				font-family: Georgia, "Times New Roman", serif;
				font-size: 1.45rem;
				line-height: 1.4;
				color: #c0392b;
				border-left: 3px solid #c0392b;
				padding: 0.2rem 0 0.2rem 1.4rem;
				margin: 2.5rem 0;
				font-style: italic;
			}
			figure { margin: 2.6rem 0; }
			figure img {
				width: 100%;
				height: auto;
				display: block;
				border-radius: 6px;
				background: #f0e8d6;
				aspect-ratio: 3 / 2;
				object-fit: cover;
				box-shadow: 0 4px 24px rgba(31, 27, 22, 0.08);
			}
			figcaption {
				font-size: 0.85rem;
				color: var(--soft);
				margin-top: 0.7rem;
				text-align: center;
			}
			.hero { margin: 2.6rem 0 2.4rem; }
			.hero img {
				aspect-ratio: 16 / 9;
				border-radius: 10px;
				box-shadow: 0 14px 40px rgba(31, 27, 22, 0.16);
			}
			.hero figcaption {
				font-style: italic;
				margin-top: 0.9rem;
			}
			strong { color: var(--ink); font-weight: 600; }
			a { color: var(--accent); }
			hr {
				border: 0;
				border-top: 1px solid var(--rule);
				margin: 3.5rem 0 1.8rem;
			}
			.credits {
				font-size: 0.78rem;
				color: var(--soft);
				line-height: 1.55;
			}
			.credits a {
				color: var(--soft);
				text-decoration: underline;
				text-underline-offset: 2px;
			}
			.signoff {
				margin-top: 2.6rem;
				font-family: Georgia, "Times New Roman", serif;
				font-size: 1.1rem;
				color: var(--accent);
				text-align: center;
				font-style: italic;
			}
			.placeholder {
				border: 1px dashed var(--rule);
				border-radius: 6px;
				padding: 2.2rem 1.6rem;
				text-align: center;
				color: var(--soft);
				font-style: italic;
				margin: 2rem 0;
			}
			@media (max-width: 640px) {
				.site-header { padding: 0.9rem 1rem; gap: 0.8rem; }
				.primary { gap: 1rem; margin: 0; order: 3; flex-basis: 100%; justify-content: center; }
				.brand { font-size: 1rem; }
			}
		</style>
	</body>
</html>
