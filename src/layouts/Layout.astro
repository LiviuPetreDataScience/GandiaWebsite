---
interface Props {
	title: string;
	lang: 'en' | 'es';
	description: string;
	otherLangHref: string;
	otherLangLabel: string;
}

const { title, lang, description, otherLangHref, otherLangLabel } = Astro.props;

const nav = lang === 'es'
	? {
		brand: 'Gandía 2026',
		home: { href: '/es/', label: 'Inicio' },
		items: [
			{ href: '/es/mar/', label: 'Mar' },
			{ href: '/es/montana/', label: 'Montaña' },
			{ href: '/es/actividades/', label: 'Actividades' },
			{ href: '/es/gastronomia/', label: 'Gastronomía' },
			{ href: '/es/hoteles/', label: 'Hoteles' },
			{ href: '/es/servicios/', label: 'Servicios y condiciones' },
			{ href: '/es/contacto/', label: 'Contacto' },
		],
	}
	: {
		brand: 'Gandía 2026',
		home: { href: '/', label: 'Home' },
		items: [
			{ href: '/sea/', label: 'Sea' },
			{ href: '/mountain/', label: 'Mountain' },
			{ href: '/activities/', label: 'Activities' },
			{ href: '/food/', label: 'Food' },
			{ href: '/hotels/', label: 'Hotels' },
			{ href: '/services/', label: 'Services & Conditions' },
			{ href: '/contact/', label: 'Contact' },
		],
	};

const path = Astro.url.pathname.replace(/\/+$/, '') + '/';
const isActive = (href: string) => path === href;

const footer = lang === 'es'
	? {
		blurb: 'Consultoría local en la costa valenciana. No somos agencia de viajes — no gestionamos reservas ni cobramos pagos. Lo que ofrecemos son recomendaciones y apoyo sobre el terreno. Las contribuciones voluntarias en Ko-fi nos ayudan a seguir.',
		links: [
			{ href: '/es/servicios/', label: 'Servicios y condiciones' },
			{ href: '/es/contacto/', label: 'Contacto' },
			{ href: '/es/privacidad/', label: 'Privacidad' },
			{ href: '/es/cookies/', label: 'Cookies' },
		],
	}
	: {
		blurb: 'Local consultancy on the Valencian coast. Not a travel agency — we don\'t handle bookings or take payments. What we offer is recommendations and on-the-ground support. Voluntary contributions on Ko-fi keep this work going.',
		links: [
			{ href: '/services/', label: 'Services & Conditions' },
			{ href: '/contact/', label: 'Contact' },
			{ href: '/privacy/', label: 'Privacy' },
			{ href: '/cookies/', label: 'Cookies' },
		],
	};
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href={nav.home.href}>{nav.brand}</a>
			<nav class="primary" id="primary-nav" aria-label="Primary">
				{nav.items.map((item) => (
					<a href={item.href} class:list={['nav-link', { active: isActive(item.href) }]}>
						{item.label}
					</a>
				))}
			</nav>
			<nav class="lang" aria-label="Language">
				<a href={otherLangHref} hreflang={otherLangHref.startsWith('/es') ? 'es' : 'en'}>
					{otherLangLabel}
				</a>
			</nav>
			<button
				class="nav-toggle"
				type="button"
				aria-controls="primary-nav"
				aria-expanded="false"
				aria-label={lang === 'es' ? 'Abrir menú' : 'Open menu'}
			>
				<svg class="icon-bars" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
					<path d="M3 6h18M3 12h18M3 18h18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
				</svg>
				<svg class="icon-close" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
					<path d="M6 6l12 12M6 18L18 6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
				</svg>
			</button>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer" aria-label={lang === 'es' ? 'Pie de página' : 'Footer'}>
			<div class="footer-inner">
				<p class="footer-blurb">
					<strong>Gandía 2026</strong> · {footer.blurb}
				</p>
				<nav class="footer-nav" aria-label={lang === 'es' ? 'Enlaces legales' : 'Legal links'}>
					{footer.links.map((item, i) => (
						<>
							{i > 0 && <span class="footer-sep" aria-hidden="true">·</span>}
							<a href={item.href}>{item.label}</a>
						</>
					))}
				</nav>
				<p class="footer-copy">© {year} Gandía 2026</p>
			</div>
		</footer>
		<aside class="float-contact" aria-label={lang === 'es' ? 'Contacto rápido' : 'Quick contact'}>
			<a
				class="float-contact-btn float-contact-wa"
				href="https://wa.me/34660740397"
				target="_blank"
				rel="noopener"
				aria-label={lang === 'es' ? 'Escríbenos por WhatsApp' : 'Message us on WhatsApp'}
			>
				<svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
					<path fill="currentColor" d="M16 3.2C8.93 3.2 3.2 8.93 3.2 16c0 2.26.6 4.46 1.74 6.4L3.2 28.8l6.55-1.72A12.8 12.8 0 0 0 16 28.8c7.07 0 12.8-5.73 12.8-12.8S23.07 3.2 16 3.2zm0 23.36c-1.98 0-3.92-.54-5.62-1.55l-.4-.24-3.89 1.02 1.04-3.79-.26-.41A10.55 10.55 0 0 1 5.44 16C5.44 10.17 10.17 5.44 16 5.44S26.56 10.17 26.56 16 21.83 26.56 16 26.56zm5.78-7.9c-.32-.16-1.88-.93-2.17-1.04-.29-.1-.5-.16-.71.16-.21.32-.82 1.04-1 1.25-.18.21-.37.24-.69.08-.32-.16-1.34-.49-2.55-1.57-.94-.84-1.58-1.88-1.77-2.2-.18-.32-.02-.5.14-.66.14-.14.32-.37.48-.55.16-.18.21-.32.32-.53.11-.21.05-.4-.03-.55-.08-.16-.71-1.72-.98-2.36-.26-.62-.52-.54-.71-.55l-.61-.01c-.21 0-.55.08-.84.4-.29.32-1.1 1.08-1.1 2.63s1.13 3.05 1.29 3.26c.16.21 2.22 3.4 5.37 4.76.75.32 1.34.51 1.8.66.76.24 1.45.21 2 .13.61-.09 1.88-.77 2.14-1.51.26-.74.26-1.38.18-1.51-.08-.13-.29-.21-.61-.37z"/>
				</svg>
			</a>
			<a
				class="float-contact-btn float-contact-mail"
				href="mailto:luizamalik@yahoo.com"
				aria-label={lang === 'es' ? 'Escríbenos por correo' : 'Email us'}
			>
				<svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
					<path fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" d="M5 8h22v16H5z"/>
					<path fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" d="M5 9l11 8 11-8"/>
				</svg>
			</a>
			<a
				class="float-contact-btn float-contact-kofi"
				href="https://ko-fi.com/luiza82"
				target="_blank"
				rel="noopener"
				aria-label={lang === 'es' ? 'Apóyanos en Ko-fi' : 'Support us on Ko-fi'}
			>
				<svg viewBox="0 0 32 32" aria-hidden="true" focusable="false">
					<path fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" d="M12 4c-.8 1.5.8 2.5 0 4M16 3c-.8 1.5.8 2.5 0 4M20 4c-.8 1.5.8 2.5 0 4"/>
					<path fill="currentColor" d="M5 11h17v9a6 6 0 0 1-6 6h-5a6 6 0 0 1-6-6V11z"/>
					<path fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round" d="M22 14h2.5a3.5 3.5 0 0 1 0 7H22"/>
				</svg>
			</a>
		</aside>
		<script is:inline>
			(() => {
				const toggle = document.querySelector('.nav-toggle');
				const nav = document.getElementById('primary-nav');
				if (!toggle || !nav) return;
				const close = () => {
					toggle.setAttribute('aria-expanded', 'false');
					nav.classList.remove('is-open');
				};
				toggle.addEventListener('click', () => {
					const open = toggle.getAttribute('aria-expanded') === 'true';
					toggle.setAttribute('aria-expanded', String(!open));
					nav.classList.toggle('is-open', !open);
				});
				nav.addEventListener('click', (e) => {
					if (e.target && e.target.tagName === 'A') close();
				});
				document.addEventListener('keydown', (e) => {
					if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
						close();
						toggle.focus();
					}
				});
			})();
		</script>
		<style is:global>
			:root {
				--ink: #1f1b16;
				--muted: #6b6258;
				--soft: #8d8478;
				--accent: #c0682a;
				--accent-soft: #e8b894;
				--bg: #faf5ec;
				--paper: #ffffff;
				--rule: #e6dcc8;
			}
			* { box-sizing: border-box; }
			html, body { margin: 0; padding: 0; overflow-x: clip; }
			body {
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
				color: var(--ink);
				background: var(--bg);
				line-height: 1.7;
				font-size: 17px;
				-webkit-font-smoothing: antialiased;
			}
			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1.2rem;
				padding: 1.1rem 1.8rem;
				border-bottom: 1px solid var(--rule);
				background: rgba(250, 245, 236, 0.92);
				backdrop-filter: saturate(140%) blur(6px);
				position: sticky;
				top: 0;
				z-index: 10;
				flex-wrap: wrap;
			}
			.brand {
				font-family: Georgia, "Times New Roman", serif;
				font-size: 1.15rem;
				font-weight: 700;
				letter-spacing: -0.01em;
				color: var(--ink);
				text-decoration: none;
			}
			.brand:hover { color: var(--accent); }
			.primary {
				display: flex;
				gap: 1.6rem;
				margin: 0 auto 0 1.2rem;
			}
			.nav-link {
				color: var(--muted);
				text-decoration: none;
				font-size: 0.95rem;
				padding: 0.2rem 0;
				border-bottom: 1.5px solid transparent;
				transition: color 0.15s, border-color 0.15s;
			}
			.nav-link:hover { color: var(--accent); }
			.nav-link.active {
				color: var(--ink);
				border-bottom-color: var(--accent);
			}
			.lang a {
				color: var(--soft);
				text-decoration: none;
				font-size: 0.85rem;
				letter-spacing: 0.05em;
				border-bottom: 1px solid var(--rule);
				padding-bottom: 2px;
			}
			.lang a:hover {
				color: var(--accent);
				border-color: var(--accent);
			}
			.nav-toggle {
				display: none;
				align-items: center;
				justify-content: center;
				width: 2.4rem;
				height: 2.4rem;
				background: transparent;
				border: 1px solid var(--rule);
				border-radius: 8px;
				color: var(--ink);
				cursor: pointer;
				padding: 0;
				transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
			}
			.nav-toggle:hover { border-color: var(--accent); color: var(--accent); }
			.nav-toggle svg { width: 1.3rem; height: 1.3rem; display: block; }
			.nav-toggle .icon-close { display: none; }
			.nav-toggle[aria-expanded="true"] {
				background: var(--paper);
				border-color: var(--accent);
				color: var(--accent);
			}
			.nav-toggle[aria-expanded="true"] .icon-bars { display: none; }
			.nav-toggle[aria-expanded="true"] .icon-close { display: block; }
			main {
				max-width: 820px;
				margin: 0 auto;
				padding: 5.5rem 1.5rem 6rem;
			}
			.eyebrow {
				display: flex;
				align-items: center;
				gap: 0.95rem;
				text-transform: uppercase;
				letter-spacing: 0.2em;
				font-size: 0.92rem;
				color: var(--accent);
				font-weight: 700;
				margin: 0 0 1.5rem;
			}
			.eyebrow::before {
				content: "";
				flex: 0 0 auto;
				width: 2.6rem;
				height: 2px;
				background: var(--accent);
			}
			h1 {
				font-family: Georgia, "Times New Roman", serif;
				font-weight: 700;
				font-size: clamp(2.4rem, 6vw, 3.8rem);
				line-height: 1.1;
				margin: 0 0 2.6rem;
				letter-spacing: -0.02em;
				color: var(--ink);
				text-align: center;
			}
			h1 .accent {
				color: var(--accent);
				font-style: italic;
				font-weight: 400;
			}
			.tagline {
				font-family: Georgia, "Times New Roman", serif;
				font-size: 1.3rem;
				color: var(--soft);
				font-style: italic;
				margin: 0.8rem 0 2.4rem;
				line-height: 1.45;
			}
			p { margin: 0 0 1.4rem; }
			.cta-top { margin: 0 0 1.6rem; text-align: center; }
			.cta {
				display: inline-block;
				background: #1f1b16;
				color: #ffffff;
				text-decoration: none;
				font-weight: 600;
				font-size: 0.92rem;
				padding: 0.7rem 1.4rem;
				border-radius: 999px;
				letter-spacing: 0.005em;
				white-space: nowrap;
				box-shadow: 0 6px 18px rgba(31, 27, 22, 0.22);
				transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
			}
			.cta:hover {
				background: #000000;
				transform: translateY(-1px);
				box-shadow: 0 9px 22px rgba(31, 27, 22, 0.32);
			}
			.lead {
				font-size: 1.12rem;
				color: var(--ink);
				margin-top: 0.4rem;
				margin-bottom: 2rem;
			}
			.lead::first-letter {
				font-family: Georgia, "Times New Roman", serif;
				font-size: 3.6rem;
				line-height: 0.9;
				float: left;
				padding: 0.35rem 0.7rem 0 0;
				color: var(--accent);
				font-weight: 700;
			}
			.eclipse-card {
				background: linear-gradient(135deg, #f9ecd6 0%, #f3dcb8 100%);
				border-left: 4px solid var(--accent);
				border-radius: 10px;
				padding: 1.6rem 1.9rem 0.6rem;
				margin: 2.6rem 0;
				box-shadow: 0 2px 14px rgba(192, 104, 42, 0.08);
			}
			.eclipse-eyebrow {
				font-family: Georgia, "Times New Roman", serif;
				text-transform: uppercase;
				letter-spacing: 0.18em;
				font-size: 0.78rem;
				color: var(--accent);
				font-weight: 700;
				margin: 0 0 0.7rem;
			}
			.eclipse-card p:last-child { margin-bottom: 1rem; }
			.eclipse-map { margin: 0.4rem 0 1.4rem; }
			.eclipse-map img {
				aspect-ratio: auto;
				object-fit: contain;
				background: var(--paper);
				border-radius: 6px;
				box-shadow: 0 2px 12px rgba(31, 27, 22, 0.08);
			}
			.eclipse-map figcaption {
				font-size: 0.78rem;
				margin-top: 0.6rem;
				text-align: center;
			}
			.tailor {
				margin-top: 2.4rem;
			}
			.pull {
				font-family: Georgia, "Times New Roman", serif;
				font-size: 1.45rem;
				line-height: 1.4;
				color: #c0392b;
				border-left: 3px solid #c0392b;
				padding: 0.2rem 0 0.2rem 1.4rem;
				margin: 2.5rem 0;
				font-style: italic;
			}
			figure { margin: 2.6rem 0; }
			figure img {
				width: 100%;
				height: auto;
				display: block;
				border-radius: 6px;
				background: #f0e8d6;
				aspect-ratio: 3 / 2;
				object-fit: cover;
				box-shadow: 0 4px 24px rgba(31, 27, 22, 0.08);
			}
			figcaption {
				font-size: 0.85rem;
				color: var(--soft);
				margin-top: 0.7rem;
				text-align: center;
			}
			.hero { margin: 2.6rem 0 2.4rem; }
			.hero img {
				aspect-ratio: 16 / 9;
				border-radius: 10px;
				box-shadow: 0 14px 40px rgba(31, 27, 22, 0.16);
			}
			.hero figcaption {
				font-style: italic;
				margin-top: 0.9rem;
			}
			strong { color: var(--ink); font-weight: 600; }
			a { color: var(--accent); }
			hr {
				border: 0;
				border-top: 1px solid var(--rule);
				margin: 3.5rem 0 1.8rem;
			}
			.credits {
				font-size: 0.78rem;
				color: var(--soft);
				line-height: 1.55;
			}
			.credits a {
				color: var(--soft);
				text-decoration: underline;
				text-underline-offset: 2px;
			}
			.signoff {
				margin-top: 2.6rem;
				font-family: Georgia, "Times New Roman", serif;
				font-size: 1.1rem;
				color: var(--accent);
				text-align: center;
				font-style: italic;
			}
			.placeholder {
				border: 1px dashed var(--rule);
				border-radius: 6px;
				padding: 2.2rem 1.6rem;
				text-align: center;
				color: var(--soft);
				font-style: italic;
				margin: 2rem 0;
			}
			.site-footer {
				border-top: 1px solid var(--rule);
				background: var(--paper);
				padding: 2.4rem 1.5rem 3rem;
			}
			.footer-inner {
				max-width: 820px;
				margin: 0 auto;
				text-align: center;
				display: flex;
				flex-direction: column;
				gap: 1.1rem;
			}
			.footer-blurb {
				font-size: 0.92rem;
				color: var(--muted);
				margin: 0;
				line-height: 1.6;
			}
			.footer-blurb strong {
				color: var(--ink);
				font-family: Georgia, "Times New Roman", serif;
				font-weight: 700;
				letter-spacing: -0.005em;
			}
			.footer-nav {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				align-items: center;
				gap: 0.4rem 0.7rem;
				font-size: 0.88rem;
			}
			.footer-nav a {
				color: var(--soft);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				padding-bottom: 1px;
				transition: color 0.15s ease, border-color 0.15s ease;
			}
			.footer-nav a:hover {
				color: var(--accent);
				border-bottom-color: var(--accent);
			}
			.footer-sep {
				color: var(--soft);
				opacity: 0.55;
			}
			.footer-copy {
				font-size: 0.78rem;
				color: var(--soft);
				margin: 0;
				letter-spacing: 0.03em;
			}
			.float-contact {
				position: fixed;
				right: 1.4rem;
				bottom: 1.4rem;
				display: flex;
				flex-direction: column;
				gap: 0.7rem;
				z-index: 50;
			}
			.float-contact-btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				width: 3.2rem;
				height: 3.2rem;
				border-radius: 50%;
				color: #ffffff;
				box-shadow: 0 6px 20px rgba(31, 27, 22, 0.28);
				transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
			}
			.float-contact-btn svg {
				width: 1.7rem;
				height: 1.7rem;
				display: block;
			}
			.float-contact-btn:hover {
				transform: translateY(-2px) scale(1.05);
				box-shadow: 0 10px 26px rgba(31, 27, 22, 0.36);
			}
			.float-contact-wa { background: #25d366; }
			.float-contact-wa:hover { background: #1ebe5b; }
			.float-contact-mail { background: var(--accent); }
			.float-contact-mail:hover { background: #a55620; }
			.float-contact-kofi { background: #ff5e5b; }
			.float-contact-kofi:hover { background: #e54f4c; }
			@media (max-width: 640px) {
				.site-header {
					padding: 0.7rem 0.9rem;
					gap: 0.5rem;
					flex-wrap: nowrap;
				}
				.brand { font-size: 1rem; order: 1; }
				.lang { order: 2; margin-left: auto; }
				.nav-toggle { display: inline-flex; order: 3; }
				.primary {
					display: none;
					position: absolute;
					top: 100%;
					left: 0;
					right: 0;
					flex-direction: column;
					gap: 0;
					margin: 0;
					background: var(--paper);
					border-top: 1px solid var(--rule);
					border-bottom: 1px solid var(--rule);
					padding: 0.3rem 1.1rem;
					box-shadow: 0 8px 18px rgba(31, 27, 22, 0.10);
					max-height: calc(100vh - 70px);
					overflow-y: auto;
				}
				.primary.is-open { display: flex; }
				.primary .nav-link {
					padding: 0.85rem 0;
					font-size: 1rem;
					border-bottom: 1px solid var(--rule);
				}
				.primary .nav-link:last-child { border-bottom: none; }
				.primary .nav-link.active {
					border-bottom-color: var(--rule);
					color: var(--accent);
				}
				.float-contact {
