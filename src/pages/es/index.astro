	<style>
		/* Full-bleed hero */
		.hero-fullbleed {
			position: relative;
			width: 100vw;
			left: calc(-50vw + 50%);
			margin-top: -5.5rem;
			margin-bottom: 3.6rem;
			height: clamp(540px, 86vh, 760px);
			overflow: hidden;
			isolation: isolate;
		}
		.hero-bg {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			object-fit: cover;
			z-index: 0;
			transform: scale(1.04);
			transform-origin: 55% 55%;
			animation: ken-burns 26s ease-in-out infinite alternate;
			will-change: transform;
		}
		@keyframes ken-burns {
			0%   { transform: scale(1.04); transform-origin: 50% 60%; }
			100% { transform: scale(1.14); transform-origin: 60% 40%; }
		}
		.hero-scrim {
			position: absolute;
			inset: 0;
			z-index: 1;
			background: linear-gradient(180deg,
				rgba(20, 16, 12, 0.18) 0%,
				rgba(20, 16, 12, 0.40) 55%,
				rgba(20, 16, 12, 0.66) 100%);
		}
		.hero-content {
			position: absolute;
			inset: 0;
			z-index: 2;
			display: grid;
			align-content: center;
			padding: 5.5rem 1.8rem 3.5rem;
			color: #fff;
			text-shadow: 0 2px 14px rgba(0, 0, 0, 0.32);
			animation: hero-rise 1.1s cubic-bezier(0.2, 0.7, 0.2, 1) 0.15s both;
		}
		.hero-content > * {
			max-width: 820px;
			margin-left: auto;
			margin-right: auto;
			width: 100%;
		}
		@keyframes hero-rise {
			from { opacity: 0; transform: translateY(18px); }
			to   { opacity: 1; transform: translateY(0); }
		}
		.hero-eyebrow {
			display: flex;
			align-items: center;
			gap: 0.95rem;
			text-transform: uppercase;
			letter-spacing: 0.22em;
			font-size: 0.85rem;
			color: #f3d3a8;
			font-weight: 700;
			margin: 0 auto 1.5rem;
		}
		.hero-eyebrow::before {
			content: "";
			flex: 0 0 auto;
			width: 2.6rem;
			height: 2px;
			background: #f3d3a8;
		}
		.hero-title {
			font-family: Georgia, "Times New Roman", serif;
			font-weight: 700;
			font-size: clamp(2.6rem, 7vw, 4.6rem);
			line-height: 1.05;
			margin: 0 auto 1.6rem;
			letter-spacing: -0.02em;
			color: #fff;
			text-align: left;
		}
		.hero-title .accent {
			color: #f3d3a8;
			font-style: italic;
			font-weight: 700;
		}
		.hero-subtitle {
			font-family: Georgia, "Times New Roman", serif;
			font-size: clamp(1.1rem, 1.9vw, 1.4rem);
			line-height: 1.5;
			color: rgba(255, 255, 255, 0.95);
			margin: 0 auto 2.4rem;
			font-style: italic;
		}
		.hero-subtitle strong {
			font-style: normal;
			color: #fff;
			font-weight: 600;
		}
		.hero-actions {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 1.4rem 2rem;
			margin: 0 auto;
		}
		.hero-cta {
			display: inline-block;
			background: var(--accent);
			color: #fff;
			text-decoration: none;
			font-weight: 700;
			font-size: 1.02rem;
			padding: 0.95rem 1.8rem;
			border-radius: 999px;
			box-shadow: 0 10px 28px rgba(0, 0, 0, 0.38);
			letter-spacing: 0.005em;
			transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
		}
		.hero-cta:hover {
			background: #d97a36;
			transform: translateY(-2px);
			box-shadow: 0 16px 36px rgba(0, 0, 0, 0.46);
		}
		.hero-scroll {
			color: rgba(255, 255, 255, 0.95);
			text-decoration: none;
			font-size: 0.95rem;
			border-bottom: 1px solid rgba(255, 255, 255, 0.5);
			padding-bottom: 2px;
			letter-spacing: 0.02em;
			transition: color 0.15s, border-color 0.15s;
		}
		.hero-scroll:hover {
			color: #f3d3a8;
			border-color: #f3d3a8;
		}

		/* Grouped home galleries (Playa Gandía 3-col + bottom 2x2) */
		.home-gallery,
		.home-gallery-3 {
			display: grid;
			gap: 0.9rem;
			margin: 2.4rem 0 3rem;
		}
		.home-gallery   { grid-template-columns: repeat(2, 1fr); }
		.home-gallery-3 { grid-template-columns: repeat(3, 1fr); margin-bottom: 5.8rem; }
		.home-gallery figure,
		.home-gallery-3 figure { margin: 0; }
		.home-gallery img,
		.home-gallery-3 img {
			width: 100%;
			height: 100%;
			aspect-ratio: 4 / 3;
			object-fit: cover;
			border-radius: 8px;
			box-shadow: 0 4px 18px rgba(31, 27, 22, 0.10);
			display: block;
		}
		.home-gallery figcaption,
		.home-gallery-3 figcaption {
			font-size: 0.82rem;
			color: var(--muted);
			margin-top: 0.5rem;
			text-align: center;
			font-style: italic;
		}
		.home-gallery-3 { gap: 0.6rem; }
		.home-gallery   { gap: 0.6rem; }
