---
import Layout from '../../layouts/Layout.astro';
---

<Layout
	lang="en"
	title="Thanks — Gandía, summer 2026"
	description="Thanks — your message has been received. We'll be back to you shortly."
	otherLangHref="/es/gracias/"
	otherLangLabel="Español"
>
	<p class="eyebrow">Thanks</p>
	<h1>Message <span class="accent">received</span></h1>
	<p class="tagline">
		We've got your message — we'll be back to you as soon as we can.
	</p>

	<p class="lead">
		Thanks for writing. We read every message and aim to reply within a few hours, often faster. If it's urgent, drop us a line on <a href="https://wa.me/34660740397" rel="noopener">WhatsApp</a> — we're on it 24/7.
	</p>

	<p class="signoff">See you on the coast.</p>

	<p class="cta-top">
		<a class="cta" href="/">Back to home →</a>
	</p>
</Layout>
